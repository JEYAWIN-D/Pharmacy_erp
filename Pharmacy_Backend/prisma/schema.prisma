generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id        String     @id @default(uuid())
  username  String     @unique
  email     String     @unique
  password  String
  isActive  Boolean    @default(true)
  roleId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  role      Role       @relation(fields: [roleId], references: [id])
  auditLogs AuditLog[]
  employee  Employee?
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  medicines   Medicine[]

  @@map("medicine_category")
}

model Manufacturer {
  id           String     @id @default(uuid())
  name         String
  country      String?
  contactEmail String?
  phone        String?
  isActive     Boolean    @default(true)
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  medicines    Medicine[]

  @@map("manufacturers")
}

model Medicine {
  id                   String                @id @default(uuid())
  medicineName         String
  genericName          String?
  brandName            String?
  skuCode              String                @unique
  medicineCode         String?
  typeId               String?
  medicineType         MedicineType?         @relation(fields: [typeId], references: [id])
  unit                 String?
  mrp                  Decimal?              @db.Decimal(10, 2)
  purchasePrice        Decimal?              @db.Decimal(10, 2)
  sellingPrice         Decimal?              @db.Decimal(10, 2)
  lowestStockLevel     Int                   @default(0)
  coldStorageRequired  Boolean               @default(false)
  statusName           String?               @default("Active")
  categoryId           String?
  supplierId           String?
  manufacturerId       String?
  companyName          String?
  pricePerPiece        Decimal               @default(0) @db.Decimal(10, 2)
  stockQuantity        Int                   @default(0)
  reorderLevel         Int                   @default(10)
  shelfLocation        String?
  storageType          String?               @default("Normal")
  taxPercentage        Decimal?              @default(0) @db.Decimal(5, 2)
  requiresDoctorSlip   Boolean               @default(false)
  isActive             Boolean               @default(true)
  isDeleted            Boolean               @default(false)
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  billItems            BillItem[]
  dispensingLogs       DispensingLog[]
  inventoryLogs        InventoryLog[]
  batches              MedicineBatch[]
  medicineLocations    MedicineLocation[]
  category             Category?             @relation(fields: [categoryId], references: [id])
  manufacturer         Manufacturer?         @relation(fields: [manufacturerId], references: [id])
  supplier             Supplier?             @relation(fields: [supplierId], references: [id])
  outletStocks         OutletStock[]
  patientReturnItems   PatientReturnItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  purchaseRequestItems PurchaseRequestItem[]
  supplierReturnItems  SupplierReturnItem[]
  warehouseStocks      WarehouseStock[]
  grnItems             GRNItem[]
  stockLedgers         StockLedger[]
  status               MedicineStatus?       @relation(fields: [statusName], references: [name])
  supplierMappings     MedicineSupplierMapping[]
  coldStorageRecords   ColdStorage[]
  rackStocks           RackStock[]
  stockMovements       StockMovement[]
  inventory            Inventory?

  @@map("medicine_master")
}

model Supplier {
  id                String            @id @default(uuid())
  name              String
  code              String            @unique
  supplierType      String?           @default("Distributor")
  contactPerson     String?
  phone             String?
  alternatePhone    String?
  email             String?
  website           String?
  secondaryPhone    String?
  addressStreet     String?
  addressCity       String?
  addressState      String?
  addressCountry    String?           @default("India")
  addressPincode    String?
  gstNumber         String?           @unique
  gstType           String?           @default("Regular")
  panNumber         String?
  drugLicenseNo     String?           @unique
  drugLicenseExpiry DateTime?
  fssaiNumber       String?
  paymentTermsDays  Int?              @default(30)
  creditLimit       Decimal?          @default(200000) @db.Decimal(12, 2)
  creditPeriod      Int?              @default(30)
  paymentMode       String?           @default("Bank Transfer")
  openingBalance    Decimal?          @default(0) @db.Decimal(12, 2)
  bankAccountName   String?
  bankAccountNumber String?
  bankIfscCode      String?
  status            String?           @default("Active")
  isPreferred       Boolean           @default(false)
  isActive          Boolean           @default(true)
  isDeleted         Boolean           @default(false)
  remarks           String?
  createdBy         String?
  updatedBy         String?
  deletedAt         DateTime?
  deletedBy         String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  medicines               Medicine[]
  purchaseOrders          PurchaseOrder[]
  supplierInvoices        SupplierInvoice[]
  supplierLedger          SupplierLedger[]
  supplierPayments        SupplierPayment[]
  supplierReturns         SupplierReturn[]
  supplierCategories      SupplierCategory[]
  grns                    GRN[]
  supplierBrandMappings   SupplierBrandMapping[]
  purchaseTerms           PurchaseTerm[]
  supplierPriceHistory    SupplierPriceHistory[]
  supplierDocuments       SupplierDocument[]
  supplierPerformance     SupplierPerformance[]
  supplierCreditNotes     SupplierCreditNote[]
  supplierAuditLogs       SupplierAuditLog[]
  supplierMappings        MedicineSupplierMapping[]
  batches                 MedicineBatch[]
  financeSupplierPayments FinanceSupplierPayment[]

  @@map("supplier_master")
}

model Rack {
  id           String        @id
  category     String?
  status       String        @default("Active")
  isDeleted    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  code         String?
  createdBy    String?
  description  String?
  location     String?
  maxCapacity  Int           @default(500)
  name         String?
  type         String?
  compartments Compartment[]
  rackStocks   RackStock[]

  @@map("racks")
}

model Compartment {
  id                String             @id
  rackId            String
  name              String
  category          String?
  suitableType      String?
  maxCapacity       Int                @default(100)
  description       String?
  status            String             @default("Active")
  createdBy         String?
  isDeleted         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  rack              Rack               @relation(fields: [rackId], references: [id])
  medicineLocations MedicineLocation[]

  @@map("compartments")
}

model MedicineLocation {
  id            Int         @id @default(autoincrement())
  medicineId    String
  qty           Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  batchNumber   String?
  compartmentId String
  unit          String?     @default("Boxes")
  compartment   Compartment @relation(fields: [compartmentId], references: [id])
  medicine      Medicine    @relation(fields: [medicineId], references: [id])

  @@map("medicine_locations")
}

model Warehouse {
  id              String           @id @default(uuid())
  name            String
  locationBin     String?
  isActive        Boolean          @default(true)
  isDeleted       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  address         String?
  city            String?
  code            String?
  contactNumber   String?
  contactPerson   String?
  createdBy       String?
  email           String?
  gps             String?
  gst             String?
  licenseExpiry   String?
  licenseNumber   String?
  parentWarehouse String?
  pincode         String?
  state           String?
  status          String           @default("Active")
  storageCapacity Int              @default(1000)
  tempZone        String?
  type            String?          @default("Branch")
  stocks          WarehouseStock[]

  @@map("warehouses")
}

model WarehouseStock {
  id             Int       @id @default(autoincrement())
  warehouseId    String
  medicineId     String
  batchNumber    String    @default("")
  qty            Int       @default(0)
  locationBin    String?
  status         String?   @default("Active")
  receivedDate   DateTime? @default(now())
  movementStatus String?   @default("In warehouse")
  updatedAt      DateTime  @updatedAt
  medicine       Medicine  @relation(fields: [medicineId], references: [id])
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, medicineId, batchNumber])
  @@map("warehouse_stocks")
}

model StockTransfer {
  id            String   @id @default(uuid())
  medicineId    String?
  medicineName  String?
  fromLocation  String?
  toRack        String?
  qty           Int
  transferredBy String?
  remarks       String?
  createdAt     DateTime @default(now())
  status        String   @default("Completed")
  transferType  String   @default("Rack to Rack")

  @@map("stock_transfers")
}

model Outlet {
  id        String        @id @default(uuid())
  name      String        @unique
  address   String?
  type      String?       @default("Branch")
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  stocks    OutletStock[]

  @@map("outlets")
}

model OutletStock {
  id         Int      @id @default(autoincrement())
  outletId   String
  medicineId String
  stock      Int      @default(0)
  rack       String?
  updatedAt  DateTime @updatedAt
  medicine   Medicine @relation(fields: [medicineId], references: [id])
  outlet     Outlet   @relation(fields: [outletId], references: [id])

  @@unique([outletId, medicineId])
  @@map("outlet_stocks")
}

model MedicineBatch {
  id                 Int             @id @default(autoincrement())
  medicineId         String
  batchNumber        String          @unique
  expiryDate         DateTime
  stockQty           Int             @default(0)
  status             String          @default("Active")
  isDeleted          Boolean         @default(false)
  mrp                Decimal?        @db.Decimal(10, 2)
  purchasePrice      Decimal?        @db.Decimal(10, 2)
  sellingPrice       Decimal?        @db.Decimal(10, 2)
  mfgDate            DateTime?
  supplierId         String?
  grnId              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  dispensingLogs     DispensingLog[]
  expiryAlerts       ExpiryAlert[]
  medicine           Medicine        @relation(fields: [medicineId], references: [id])
  supplier           Supplier?       @relation(fields: [supplierId], references: [id])
  grn                GRN?            @relation(fields: [grnId], references: [id])
  coldStorageRecords ColdStorage[]

  @@map("medicine_batches")
}

model InventoryLog {
  id           Int       @id @default(autoincrement())
  medicineId   String?
  medicineName String?
  type         String
  qty          Int
  user         String?
  remarks      String?
  createdAt    DateTime  @default(now())
  medicine     Medicine? @relation(fields: [medicineId], references: [id])

  @@map("inventory_logs")
}

model ExpiryAlert {
  id           String        @id @default(uuid())
  batchId      Int
  medicineId   String
  medicineName String?
  expiryDate   DateTime
  daysLeft     Int
  alertTier    String
  action       String        @default("Active")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  batch        MedicineBatch @relation(fields: [batchId], references: [id])

  @@map("expiry_alerts")
}

model PurchaseRequest {
  id          String                @id @default(uuid())
  requestDate DateTime              @default(now())
  priority    String                @default("Normal")
  status      String                @default("Pending")
  requestedBy String?
  remarks     String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  items       PurchaseRequestItem[]

  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                Int             @id @default(autoincrement())
  purchaseRequestId String
  medicineId        String
  medicineName      String?
  requestedQty      Int
  medicine          Medicine        @relation(fields: [medicineId], references: [id])
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])

  @@map("purchase_request_items")
}

model PurchaseOrder {
  id                  String              @id @map("po_id")
  supplierId          String?             @map("supplier_id")
  prId                String?             @map("pr_id")
  poDate              DateTime            @default(now()) @map("po_date")
  poTime              String?             @map("po_time")
  status              String              @default("Draft")
  subtotal            Decimal             @default(0) @db.Decimal(10, 2) @map("subtotal")
  total               Decimal             @default(0) @db.Decimal(10, 2) @map("total_amount")
  paymentTerms        String?             @default("Net 30") @map("payment_terms")
  communicationMethod String?             @default("Email") @map("communication_method")
  createdBy           String?             @map("created_by")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  grns                GRN[]
  items               PurchaseOrderItem[]
  supplier            Supplier?           @relation(fields: [supplierId], references: [id])

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement()) @map("po_item_id")
  purchaseOrderId String        @map("po_id")
  medicineId      String        @map("medicine_id")
  medicineName    String?       @map("medicine_name")
  qty             Int           @map("ordered_qty")
  defaultPrice    Decimal       @default(0) @db.Decimal(10, 2) @map("default_price")
  unitPrice       Decimal       @db.Decimal(10, 2) @map("modified_price")
  tax             Decimal?      @default(0) @db.Decimal(5, 2)
  total           Decimal       @db.Decimal(10, 2) @map("item_total")
  receivedQty     Int           @default(0) @map("received_qty")
  damagedQty      Int           @default(0) @map("damaged_qty")
  cancelledQty    Int           @default(0) @map("cancelled_qty")
  status          String        @default("Pending") @map("item_status")
  medicine        Medicine      @relation(fields: [medicineId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_items")
}

model GRN {
  id            String          @id @map("grn_id")
  poId          String          @map("po_id")
  supplierId    String?         @map("supplier_id")
  shipmentId    String?         @map("shipment_id")
  invoiceNumber String?         @map("invoice_number")
  receivedDate  DateTime        @default(now()) @map("created_date")
  receivedBy    String?         @map("received_by")
  status        String          @default("Verified & Approved") @map("grn_status")
  savedAsDraft  Boolean         @default(false) @map("saved_as_draft")
  completedDate DateTime?       @map("completed_date")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  items         GRNItem[]
  purchaseOrder PurchaseOrder   @relation(fields: [poId], references: [id])
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  batches       MedicineBatch[]

  @@map("grn")
}

model GRNItem {
  id            Int      @id @default(autoincrement()) @map("grn_item_id")
  grnId         String   @map("grn_id")
  medicineId    String   @map("medicine_id")
  medicineName  String?  @map("medicine_name")
  orderedQty    Int      @default(0) @map("ordered_qty")
  receivedQty   Int      @default(0) @map("received_qty")
  damagedQty    Int      @default(0) @map("damaged_qty")
  acceptedQty   Int      @default(0) @map("accepted_qty")
  pendingQty    Int      @default(0) @map("pending_qty")
  cancelledQty  Int      @default(0) @map("cancelled_qty")
  batchNumber   String?  @map("batch_number")
  expiryDate    DateTime? @map("expiry_date")
  mfgDate       DateTime? @map("mfg_date")
  status        String   @default("Pending") @map("item_status")
  remarks       String?  @map("remarks")
  cancelledBy   String?  @map("cancelled_by")
  cancelledDate String?  @map("cancelled_date")
  cancelledTime String?  @map("cancelled_time")
  cancelReason  String?  @map("cancel_reason")
  grn           GRN      @relation(fields: [grnId], references: [id])
  medicine      Medicine @relation(fields: [medicineId], references: [id])

  @@map("grn_items")
}

model Prescription {
  id             String             @id @default(uuid())
  patientName    String
  doctorName     String?
  department     String?
  date           DateTime           @default(now())
  status         String             @default("Pending")
  entryMode      String?            @default("System")
  isDeleted      Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  dispensingLogs DispensingLog[]
  items          PrescriptionItem[]

  @@map("prescriptions")
}

model PrescriptionItem {
  id             Int          @id @default(autoincrement())
  prescriptionId String
  medicineName   String
  qty            Int
  dosage         String?
  note           String?
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  @@map("prescription_items")
}

model DispensingLog {
  id             Int            @id @default(autoincrement())
  prescriptionId String?
  medicineId     String?
  medicineName   String?
  batchId        Int?
  batchNumber    String?
  qty            Int
  dispensedBy    String?
  fefoApplied    Boolean        @default(false)
  createdAt      DateTime       @default(now())
  batch          MedicineBatch? @relation(fields: [batchId], references: [id])
  medicine       Medicine?      @relation(fields: [medicineId], references: [id])
  prescription   Prescription?  @relation(fields: [prescriptionId], references: [id])

  @@map("dispensing_logs")
}

model Customer {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String?
  phone              String?
  loyaltyPoints      Int      @default(0)
  outstandingBalance Decimal  @default(0) @db.Decimal(10, 2)
  isDeleted          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  bills              Bill[]

  @@map("customers")
}

model Bill {
  id               String               @id
  customerId       Int?
  patientName      String?
  subtotal         Decimal              @default(0) @db.Decimal(10, 2)
  discount         Decimal              @default(0) @db.Decimal(10, 2)
  gstTax           Decimal              @default(0) @db.Decimal(10, 2)
  roundOff         Decimal              @default(0) @db.Decimal(10, 2)
  grandTotal       Decimal              @default(0) @db.Decimal(10, 2)
  paymentStatus    String               @default("Unpaid")
  paymentMethod    String?
  isDeleted        Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  balanceAmount    Decimal              @default(0) @db.Decimal(10, 2)
  billType         String               @default("Normal")
  changeReturned   Decimal              @default(0) @db.Decimal(10, 2)
  createdBy        String?
  doctorName       String?
  mobileNumber     String?
  paidAmount       Decimal              @default(0) @db.Decimal(10, 2)
  prescriptionNo   String?
  printedStatus    String               @default("Printed")
  notes            String?
  updatedBy        String?
  voidReason       String?
  voidedAt         DateTime?
  voidedBy         String?
  lastPrintedAt    DateTime?
  printCount       Int                  @default(0)
  prescriptionFile String?
  items            BillItem[]
  customer         Customer?            @relation(fields: [customerId], references: [id])
  patientReturns   PatientReturn[]
  transactions     PaymentTransaction[]

  @@map("bills")
}

model BillItem {
  id          Int       @id @default(autoincrement())
  billId      String
  medicineId  String?
  name        String
  qty         Int
  price       Decimal   @db.Decimal(10, 2)
  gstRate     Decimal   @default(0) @db.Decimal(5, 2)
  total       Decimal   @db.Decimal(10, 2)
  batchNumber String?
  discount    Decimal?  @default(0) @db.Decimal(10, 2)
  expiryDate  String?
  sellingUnit String?
  totalPieces Int?
  unitType    String?
  bill        Bill      @relation(fields: [billId], references: [id])
  medicine    Medicine? @relation(fields: [medicineId], references: [id])

  @@map("bill_items")
}

model PaymentTransaction {
  id             Int      @id @default(autoincrement())
  billId         String
  cashPaid       Decimal  @default(0) @db.Decimal(10, 2)
  upiPaid        Decimal  @default(0) @db.Decimal(10, 2)
  cardPaid       Decimal  @default(0) @db.Decimal(10, 2)
  insuranceClaim Decimal  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  bill           Bill     @relation(fields: [billId], references: [id])

  @@map("payment_transactions")
}

model CashRegister {
  id             Int      @id @default(autoincrement())
  openedBy       String?
  openingBalance Decimal  @default(0) @db.Decimal(10, 2)
  closingBalance Decimal? @db.Decimal(10, 2)
  status         String   @default("Open")
  cashSales      Decimal  @default(0) @db.Decimal(10, 2)
  upiSales       Decimal  @default(0) @db.Decimal(10, 2)
  cardSales      Decimal  @default(0) @db.Decimal(10, 2)
  totalSales     Decimal  @default(0) @db.Decimal(10, 2)
  notes          String?
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("cash_registers")
}

model BillingQueue {
  id               String   @id @default(uuid())
  queueId          String   @unique
  customerName     String?
  mobileNumber     String?
  items            Json     @default("[]")
  draftTotalAmount Decimal  @default(0) @db.Decimal(10, 2)
  createdTime      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("billing_queue")
}

model PatientReturn {
  id           Int                 @id @default(autoincrement())
  billId       String?
  patientName  String?
  refundAmount Decimal             @default(0) @db.Decimal(10, 2)
  reason       String?
  processedBy  String?
  createdAt    DateTime            @default(now())
  items        PatientReturnItem[]
  bill         Bill?               @relation(fields: [billId], references: [id])

  @@map("patient_returns")
}

model PatientReturnItem {
  id              Int           @id @default(autoincrement())
  patientReturnId Int
  medicineId      String?
  medicineName    String?
  qty             Int
  medicine        Medicine?     @relation(fields: [medicineId], references: [id])
  patientReturn   PatientReturn @relation(fields: [patientReturnId], references: [id])

  @@map("patient_return_items")
}

model SupplierReturn {
  id           Int                  @id @default(autoincrement())
  returnNumber String?              @unique
  supplierId   String?
  supplierName String?
  grnId        String?
  creditAmount Decimal              @default(0) @db.Decimal(10, 2)
  returnValue  Decimal              @default(0) @db.Decimal(10, 2)
  reason       String?
  status       String               @default("Pending")
  processedBy  String?
  remarks      String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  items        SupplierReturnItem[]
  creditNotes  SupplierCreditNote[]
  supplier     Supplier?            @relation(fields: [supplierId], references: [id])

  @@map("supplier_returns")
}

model SupplierReturnItem {
  id               Int            @id @default(autoincrement())
  supplierReturnId Int
  medicineId       String?
  medicineName     String?
  batchNumber      String?
  qty              Int
  unitPrice        Decimal?       @db.Decimal(10, 2)
  medicine         Medicine?      @relation(fields: [medicineId], references: [id])
  supplierReturn   SupplierReturn @relation(fields: [supplierReturnId], references: [id])

  @@map("supplier_return_items")
}

model SupplierInvoice {
  id            String    @id @default(uuid())
  supplierId    String?
  invoiceNumber String
  amount        Decimal   @db.Decimal(10, 2)
  date          DateTime  @default(now())
  remarks       String?
  status        String    @default("Unpaid")
  vehicleNumber String?
  deliveredBy   String?
  receivedBy    String?
  contactNumber String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])

  @@map("supplier_invoices")
}

model SupplierPayment {
  id              String    @id @default(uuid())
  supplierId      String?
  referenceNumber String?
  amount          Decimal   @db.Decimal(10, 2)
  method          String?
  date            DateTime  @default(now())
  remarks         String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])

  @@map("supplier_payments")
}

model SupplierLedger {
  id         String    @id @default(uuid())
  supplierId String?
  type       String
  amount     Decimal   @db.Decimal(10, 2)
  date       DateTime  @default(now())
  remarks    String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  @@map("supplier_ledger")
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

model ColdStorageLog {
  id          Int      @id @default(autoincrement())
  temperature Decimal  @db.Decimal(5, 2)
  status      String   @default("Normal")
  notes       String?
  recordedAt  DateTime @default(now())

  @@map("cold_storage_logs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String?
  userName  String?
  action    String
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Expense {
  id        Int      @id @default(autoincrement())
  category  String
  amount    Decimal  @db.Decimal(10, 2)
  remarks   String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expenses")
}

model Department {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]

  @@map("departments")
}

model Designation {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]

  @@map("designations")
}

model AppSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

model Shift {
  id          String          @id @default(uuid())
  name        String          @unique
  startTime   String
  endTime     String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assignments EmployeeShift[]

  @@map("shifts")
}

model Employee {
  id             String             @id @default(uuid())
  empCode        String             @unique
  firstName      String
  lastName       String
  gender         String?
  dob            DateTime?
  mobile         String
  email          String             @unique
  address        String?
  joiningDate    DateTime
  basicSalary    Decimal            @db.Decimal(10, 2)
  employmentType String
  status         String             @default("Active")
  departmentId   String?
  designationId  String?
  userId         String?            @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  attendances    Attendance[]
  documents      EmployeeDocument[]
  shifts         EmployeeShift?
  department     Department?        @relation(fields: [departmentId], references: [id])
  designation    Designation?       @relation(fields: [designationId], references: [id])
  user           User?              @relation(fields: [userId], references: [id])
  leaves         Leave[]
  payrolls       Payroll[]

  @@map("employees")
}

model EmployeeShift {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  shiftId      String
  assignedDate DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id])
  shift        Shift    @relation(fields: [shiftId], references: [id])

  @@map("employee_shifts")
}

model Attendance {
  id           String    @id @default(uuid())
  employeeId   String
  date         DateTime  @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  workingHours Decimal?  @db.Decimal(5, 2)
  status       String    @default("Present")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("attendances")
}

model Leave {
  id         String   @id @default(uuid())
  employeeId String
  leaveType  String
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  reason     String?
  status     String   @default("Pending")
  approvedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("leaves")
}

model Payroll {
  id           String   @id @default(uuid())
  employeeId   String
  payrollMonth String
  basicSalary  Decimal  @db.Decimal(10, 2)
  allowances   Decimal  @default(0) @db.Decimal(10, 2)
  deductions   Decimal  @default(0) @db.Decimal(10, 2)
  netSalary    Decimal  @db.Decimal(10, 2)
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employee     Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, payrollMonth])
  @@map("payrolls")
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeId   String
  documentType String
  fileUrl      String
  uploadDate   DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_documents")
}

// ─── SUPPLIER MODULE MODELS ───────────────────────────────────────────────────

model SupplierCategory {
  id                String    @id @default(uuid())
  supplierId        String
  categoryName      String
  isPreferred       Boolean   @default(false)
  isDefaultSupplier Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  supplier          Supplier  @relation(fields: [supplierId], references: [id])

  @@unique([supplierId, categoryName])
  @@map("supplier_categories")
}

model SupplierBrandMapping {
  id            String    @id @default(uuid())
  supplierId    String
  brandName     String
  genericName   String?
  medicineName  String?
  medicineId    String?
  strength      String?
  packSize      String?
  manufacturer  String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  supplier      Supplier  @relation(fields: [supplierId], references: [id])

  @@map("supplier_brand_mappings")
}

model PurchaseTerm {
  id            String    @id @default(uuid())
  supplierId    String
  medicineId    String?
  medicineName  String?
  purchasePrice Decimal   @db.Decimal(10, 2)
  gstPercent    Decimal?  @default(0) @db.Decimal(5, 2)
  discount      Decimal?  @default(0) @db.Decimal(5, 2)
  scheme        String?
  moq           Int?      @default(1)
  leadTimeDays  Int?      @default(3)
  paymentTerms  String?
  creditDays    Int?      @default(30)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  supplier      Supplier  @relation(fields: [supplierId], references: [id])

  @@map("purchase_terms")
}

model SupplierPriceHistory {
  id            String    @id @default(uuid())
  supplierId    String
  medicineId    String?
  medicineName  String?
  brandName     String?
  purchasePrice Decimal   @db.Decimal(10, 2)
  gstPercent    Decimal?  @default(0) @db.Decimal(5, 2)
  discount      Decimal?  @default(0) @db.Decimal(5, 2)
  scheme        String?
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  changedBy     String?
  changeReason  String?
  createdAt     DateTime  @default(now())
  supplier      Supplier  @relation(fields: [supplierId], references: [id])

  @@map("supplier_price_history")
}

model SupplierDocument {
  id           String    @id @default(uuid())
  supplierId   String
  documentType String
  documentName String?
  fileName     String
  filePath     String?
  fileSize     Int?
  mimeType     String?
  expiryDate   DateTime?
  status       String    @default("Active")
  uploadedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  supplier     Supplier  @relation(fields: [supplierId], references: [id])

  @@map("supplier_documents")
}

model SupplierPerformance {
  id                    String    @id @default(uuid())
  supplierId            String
  periodStart           DateTime?
  periodEnd             DateTime?
  deliveryRate          Decimal?  @default(0) @db.Decimal(5, 2)
  delayPercent          Decimal?  @default(0) @db.Decimal(5, 2)
  returnPercent         Decimal?  @default(0) @db.Decimal(5, 2)
  damagePercent         Decimal?  @default(0) @db.Decimal(5, 2)
  shortSupplyPercent    Decimal?  @default(0) @db.Decimal(5, 2)
  avgLeadTimeDays       Decimal?  @default(0) @db.Decimal(5, 2)
  priceStability        Decimal?  @default(0) @db.Decimal(5, 2)
  marginPercent         Decimal?  @default(0) @db.Decimal(5, 2)
  revenueContribution   Decimal?  @default(0) @db.Decimal(5, 2)
  purchaseContribution  Decimal?  @default(0) @db.Decimal(5, 2)
  overallRating         Decimal?  @default(0) @db.Decimal(3, 1)
  calculatedAt          DateTime  @default(now())
  supplier              Supplier  @relation(fields: [supplierId], references: [id])

  @@map("supplier_performance")
}

model SupplierCreditNote {
  id               String          @id @default(uuid())
  creditNoteNumber String          @unique
  supplierId       String
  returnId         Int?
  amount           Decimal         @db.Decimal(10, 2)
  adjustedAmount   Decimal?        @default(0) @db.Decimal(10, 2)
  status           String          @default("Pending")
  remarks          String?
  createdBy        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  supplier         Supplier        @relation(fields: [supplierId], references: [id])
  supplierReturn   SupplierReturn? @relation(fields: [returnId], references: [id])

  @@map("supplier_credit_notes")
}

model SupplierAuditLog {
  id         String   @id @default(uuid())
  supplierId String?
  action     String
  entity     String?
  entityId   String?
  oldValue   String?
  newValue   String?
  userId     String?
  userName   String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  @@map("supplier_audit_logs")
}

model StockLedger {
  id              String   @id @default(uuid()) @map("stock_ledger_id")
  medicineId      String   @map("medicine_id")
  batchNumber     String   @map("batch_number")
  transactionType String   @map("transaction_type")
  quantity        Int      @map("quantity")
  referenceId     String   @map("reference_id")
  createdDate     DateTime @default(now()) @map("created_date")
  medicine        Medicine @relation(fields: [medicineId], references: [id])

  @@map("stock_ledger")
}

// ─── NEW CONNECTED MODELS ────────────────────────────────────────────────────

model MedicineType {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  medicines   Medicine[]

  @@map("medicine_type")
}

model MedicineStatus {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  medicines Medicine[]

  @@map("medicine_status")
}

model MedicineSupplierMapping {
  id                String   @id @default(uuid())
  supplierId        String
  medicineId        String
  isDefault         Boolean  @default(false)
  purchasePrice     Decimal  @db.Decimal(10, 2)
  lastPurchasePrice Decimal? @db.Decimal(10, 2)
  leadTimeDays      Int      @default(3)
  minOrderQty       Int      @default(1)
  status            String   @default("Active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  supplier          Supplier @relation(fields: [supplierId], references: [id])
  medicine          Medicine @relation(fields: [medicineId], references: [id])

  @@unique([supplierId, medicineId])
  @@map("medicine_supplier_mapping")
}

model ColdStorage {
  id                  String         @id @default(uuid())
  medicineId          String
  batchId             Int?
  requiredTemperature String?
  currentTemperature  Decimal?       @db.Decimal(5, 2)
  storagePlace        String?
  rackFridgeLocation  String?
  status              String         @default("Active")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  medicine            Medicine       @relation(fields: [medicineId], references: [id])
  batch               MedicineBatch? @relation(fields: [batchId], references: [id])

  @@map("cold_storage")
}

model RackStock {
  id          Int      @id @default(autoincrement())
  rackId      String
  medicineId  String
  batchNumber String   @default("")
  qty         Int      @default(0)
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rack        Rack     @relation(fields: [rackId], references: [id])
  medicine    Medicine @relation(fields: [medicineId], references: [id])

  @@unique([rackId, medicineId, batchNumber])
  @@map("rack_stock")
}

model StockMovement {
  id           String   @id @default(uuid())
  medicineId   String
  batchNumber  String?
  warehouseId  String?
  rackId       String?
  qty          Int
  movedDate    DateTime @default(now())
  movedBy      String?
  transferType String   // 'Warehouse to Rack', 'Rack to Warehouse', 'Rack to Rack'
  remarks      String?
  status       String   @default("Completed")
  medicine     Medicine @relation(fields: [medicineId], references: [id])

  @@map("stock_movements")
}

model Inventory {
  id             String   @id @default(uuid())
  medicineId     String   @unique
  totalStock     Int      @default(0)
  warehouseStock Int      @default(0)
  rackStock      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  medicine       Medicine @relation(fields: [medicineId], references: [id])

  @@map("inventory")
}

model FinanceSupplierPayment {
  id             String    @id @default(uuid())
  supplierId     String
  supplierName   String
  poId           String?
  grnId          String?
  invoiceNumber  String?
  purchaseAmount Decimal   @db.Decimal(10, 2)
  paidAmount     Decimal   @default(0) @db.Decimal(10, 2)
  pendingAmount  Decimal   @db.Decimal(10, 2)
  paymentDate    DateTime?
  paymentMode    String?
  status         String    @default("Pending") // 'Pending', 'Partially Paid', 'Paid'
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  supplier       Supplier  @relation(fields: [supplierId], references: [id])

  @@map("finance_supplier_payments")
}
